# Required secrets — set these before running docker compose up
CONTROL_DB_PASSWORD=changeme
MASTER_KEY=           # 32-byte hex key: openssl rand -hex 32
SESSION_SECRET=       # 64-char random string: openssl rand -hex 32

# Optional: explicit public IP for apex DNS verification (falls back to auto-detect)
SELFBASE_PUBLIC_IP=

# Optional: ACME directory override (use staging to avoid rate limits during dev/testing)
# Production (default):  https://acme-v02.api.letsencrypt.org/directory
# Staging (fake certs):  https://acme-staging-v02.api.letsencrypt.org/directory
ACME_DIRECTORY_URL=

# Optional: selfbase container image version tag (default: dev = local build)
SELFBASE_VERSION=dev

# Optional: log level for api + worker containers (default: info)
LOG_LEVEL=info

# Optional: set COOKIE_SECURE=1 once HTTPS is in place (default: 0)
COOKIE_SECURE=0
