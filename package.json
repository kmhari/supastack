{
  "name": "supastack",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hosted Supabase Cloud control plane — provision and manage multiple full-stack Supabase instances on a single host.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "lint": "eslint . && node scripts/check-test-collection.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "node scripts/coverage.mjs",
    "test:cli": "tests/cli-e2e/deploy-hello.sh",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @supastack/db db:generate",
    "db:migrate": "pnpm --filter @supastack/db db:migrate",
    "dev:api": "pnpm --filter @supastack/api dev",
    "dev:worker": "pnpm --filter @supastack/worker dev",
    "dev:web": "pnpm --filter @supastack/web dev"
  },
  "devDependencies": {
    "@types/node": "^20.16.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.10.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
