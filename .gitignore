# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
build/
.next/
out/

# Test + coverage
coverage/
.nyc_output/
*.log
logs/

# Env + secrets — NEVER COMMIT
.env
.env.local
.env.*.local
*.pem
*.key
!packages/db/migrations/*.sql

# Editor / OS
.DS_Store
Thumbs.db
*.swp
*.tmp
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/

# Caches
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
*.tsbuildinfo

# Python (Drizzle migrations might generate Python helpers; harmless guard)
__pycache__/
*.pyc
.venv/
venv/

# Runtime per-instance data (host bind mounts)
/var/supastack/
volumes/
# But DO track the supabase-template volumes (functions main/index.ts is
# supastack-owned source code, not runtime data — copied to per-instance
# volumes at provision time).
!infra/supabase-template/volumes/
!infra/supabase-template/volumes/**

# Vendored upstream — clone is fine to track; the dynamic Studio build output is not
infra/studio/dist/
infra/supabase-template/.local/

# NOTE: do NOT add `lib/` here — this aggressive pattern broke Multibase's
# dashboard build because it gitignored apps/web/src/lib/api.ts. CI asserts
# `git check-ignore -v` on src/lib/api.ts to keep this guarantee.

# Stray supabase CLI working dir (e.g. /supabase/.temp/) when commands are run
# from the repo root by accident
/supabase/
.claude/worktrees/


# Deno (used only by infra/.../main.test.ts; URL imports are pinned)
deno.lock

# E2E test evidence outputs (regenerated on each run; attach to PR
# descriptions, don't track).
tests/cli-e2e/.evidence/

# Playwright browser-test outputs (feature 021)
apps/web/playwright-report/
apps/web/test-results/
apps/web/tests/e2e/.auth/

# CLI test artifacts
.supabase_token
.supastack

# Local Claude harness state
.claude/scheduled_tasks.lock

# Local-only dev context — removed from git history 2026-06-12, never re-track
.claude/
.specify/
specs/
specs-docs/
develop/

# Generated docs mirror for GitHub Pages (source of truth is /docs)
website/docs/
