{
  "name": "@supastack/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/main.ts",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "sync:functions-main": "tsx src/scripts/sync-functions-main.ts"
  },
  "dependencies": {
    "@supastack/backup-store": "workspace:*",
    "@supastack/crypto": "workspace:*",
    "@supastack/db": "workspace:*",
    "@supastack/docker-control": "workspace:*",
    "@supastack/shared": "workspace:*",
    "bullmq": "^5.12.0",
    "drizzle-orm": "^0.33.0",
    "ioredis": "^5.4.1",
    "pg": "^8.13.0",
    "undici": "^6.19.7"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
