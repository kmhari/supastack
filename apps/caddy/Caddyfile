# Supastack Caddy skeleton — boot-time minimum.
#
# This file defines what's reachable from the moment Caddy starts, BEFORE the
# supastack API has pushed any per-instance routes via the admin API. Two
# critical properties:
#
#   1. :80 ALWAYS serves the dashboard in plain HTTP, regardless of whether
#      an apex domain has been registered. This is how the operator reaches
#      /setup at `http://<server-ip>/` before any DNS is configured (the
#      chicken-and-egg fix).
#
#   2. :443 is enabled with on-demand TLS, gated by /internal/tls/ask. Even
#      before any instance is provisioned, this server exists so that the
#      moment the apex is set + DNS resolves, the first HTTPS request gets
#      its cert issued automatically.
#
# Per-instance routes (one per <ref>.<apex>) are added at runtime by
# `apps/api/src/services/caddy-reload.ts`, which POSTs a complete JSON
# config to the admin API. That config preserves the :80 plumbing below.
{
	admin :2019 {
		# Caddy 2.7+ enforces an Origin/Host header check on the admin API.
		# Must include the EXACT Host header value (with port). The api and
		# worker containers connect via http://caddy:2019 → Host: "caddy:2019".
		# The admin port is NOT published externally (infra/docker-compose.yml).
		origins caddy:2019 api:2019 worker:2019 localhost:2019 127.0.0.1:2019
	}

	on_demand_tls {
		# Caddy calls this before issuing a cert for any unfamiliar hostname.
		# 2xx = allow issuance; non-2xx = deny.
		# Caddy 2.7+ replaced bare `ask` with the http permission module.
		permission http http://api:3001/internal/tls/ask
	}

	# Override for ACME staging during development:
	#   CADDY_ACME_CA=https://acme-staging-v02.api.letsencrypt.org/directory
}

# Plain HTTP — always reachable. No unconditional redirect to HTTPS;
# /setup must work over plain HTTP at first install, before DNS.
:80 {
	# ACME HTTP-01 challenges for per-project Postgres certs (feature 005
	# Option B). LE hits http://db.<ref>.<apex>/.well-known/acme-challenge/<token>
	# regardless of hostname — api serves the token from an in-memory map.
	# Must come BEFORE /api/* so the well-known path always wins.
	handle /.well-known/acme-challenge/* {
		reverse_proxy api:3001
	}
	# /api/get-deployment-commit — Studio Next.js route that returns 404 in dev
	# mode; stub it at the API level instead.
	handle /api/get-deployment-commit {
	handle /api/incident-banner {
		reverse_proxy api:3001
	}		reverse_proxy api:3001
	}
	# /api/v1/* → Supastack API (includes /api/v1/v1/* which is handled
	# internally by the double-v1 Fastify catch-all in server.ts).
	# Other /api/* paths (Studio Next.js routes) fall through to Studio.
	handle /api/v1* {
		reverse_proxy api:3001
	}
	# Feature 086 US1 — base=root cutover: apex /v1* → api (disjoint from /api/v1*)
	handle /v1* {
		reverse_proxy api:3001
	}
	# Platform proxy routes (feature 025 — shared Studio)
	handle /platform/* {
		reverse_proxy api:3001
	}
	# WebSockets go to api too
	@websocket {
		path /socket.io/*
	}
	handle @websocket {
		reverse_proxy api:3001
	}
	# Internal endpoints are NEVER exposed externally
	handle /internal/* {
		respond 404
	}
	# Setup wizard + admin-only Supastack pages stay on the web SPA
	handle /setup* {
		reverse_proxy web:80
	}
	# Feature 086 US5 — boot default is GATED: redirect everything to /setup
	# until first-time setup is done. The runtime caddy-config.ts (DB-aware)
	# swaps this for the studio catch-all once setup_state.completed_at is set.
	handle {
		redir /setup 302
	}
}

# mcp.<apex> — supastack MCP HTTP service (feature 014). Matched BEFORE the
# generic :443 block so it wins for the mcp subdomain. Wildcard cert
# (*.<apex>) from feature 004 covers it; on-demand TLS still fires the first
# time if a fresh cert is needed.
mcp.{$SUPASTACK_APEX} {
	tls {
		on_demand
	}
	reverse_proxy mcp:3002
}

# Feature 107 — dedicated API host (api.<apex>) for the platform + Management API
# (mirrors Supabase's api.supabase.com). The whole host → api:3001, which demuxes
# by path (/platform/*, /v1/*) and 404s anything else — it does NOT serve the
# studio. The runtime caddy-config.ts has the same `apiHostRoute`; this is cold-boot
# parity. The base=root Studio (apex) calls this host cross-origin (scoped CORS).
api.{$SUPASTACK_APEX} {
	tls {
		on_demand
	}
	reverse_proxy api:3001
}

# Plain HTTPS — always listening so on-demand TLS can fire. The runtime
# config from caddy-reload.ts adds per-host (apex + <ref>.<apex>) routes
# on top of this.
:443 {
	tls {
		on_demand
	}
	# Default: route to dashboard. Per-instance routes are inserted via
	# the admin API and matched before this fallback.
	handle /api/get-deployment-commit {
		reverse_proxy api:3001
	}
	handle /api/v1* {
	handle /api/incident-banner {
		reverse_proxy api:3001
	}		reverse_proxy api:3001
	}
	# Feature 086 US1 — base=root cutover: apex /v1* → api (disjoint from /api/v1*)
	handle /v1* {
		reverse_proxy api:3001
	}
	# Platform proxy routes (feature 025 — shared Studio)
	handle /platform/* {
		reverse_proxy api:3001
	}
	@websocket {
		path /socket.io/*
	}
	handle @websocket {
		reverse_proxy api:3001
	}
	handle /internal/* {
		respond 404
	}
	# Setup wizard + admin-only Supastack pages stay on the web SPA
	handle /setup* {
		reverse_proxy web:80
	}
	# Feature 086 US5 — boot default is GATED (redirect to /setup until setup
	# done; runtime caddy-config.ts swaps in the studio catch-all post-setup).
	handle {
		redir /setup 302
	}
}
